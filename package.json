{
  "name": "space-maze",
  "version": "1.0.0",
  "description": "Space maze explorer built with Astro and Three.js.",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "astro": "astro",
    "deploy": "bun run build && npx wrangler deploy",
    "deploy:dry-run": "npx wrangler deploy --dry-run",
    "lint": "oxlint",
    "format": "oxfmt",
    "prepare": "husky",
    "lint:fix": "oxlint --fix . && oxfmt"
  },
  "dependencies": {
    "astro": "^6.0.4",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.7",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.37.0",
    "oxlint": "^1.55.0",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "oxlint --fix",
      "oxfmt"
    ]
  },
  "packageManager": "bun@1.3.10"
}
